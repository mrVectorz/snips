# Using Fedora 43 as requested
FROM fedora:43

RUN dnf install -y \
    turbostat \
    perf \
    pcm \
    dpdk \
    dpdk-tools \
    pciutils \
    util-linux \
    rdma-core \
    libibverbs \
    ethtool \
    iproute \
    procps-ng \
    grep \
    sed \
    tar \
    findutils \
    && dnf clean all

# Copy the collection script into the image
COPY collect_script.sh /usr/local/bin/collect_script.sh

# Make the script executable
RUN chmod +x /usr/local/bin/collect_script.sh

# Set the working directory to /tmp for easy file collection
WORKDIR /tmp

# Default command is just bash so the debug session stays open
CMD ["/bin/bash"]
